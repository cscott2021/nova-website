---
const year = new Date().getFullYear();
---

<footer class="relative border-t border-nova-border/30 bg-nova-deep">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <!-- Brand -->
      <div class="flex flex-col gap-3">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-nova-violet to-nova-lavender flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
              <g transform="translate(10, 10)">
                <rect x="-0.8" y="-7" width="1.6" height="14" rx="0.8" fill="white" opacity="0.9"/>
                <rect x="-7" y="-0.8" width="14" height="1.6" rx="0.8" fill="white" opacity="0.9"/>
                <circle r="1.5" fill="white"/>
              </g>
            </svg>
          </div>
          <span class="font-heading text-lg font-bold text-nova-text">Nova</span>
        </div>
        <p class="text-sm text-nova-text-dim max-w-xs">
          The AI-powered productivity cockpit for builders, developers, and leaders.
        </p>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-8 text-sm">
        <a href="#features" class="text-nova-text-dim hover:text-nova-lavender transition-colors">Features</a>
        <a href="#how-it-works" class="text-nova-text-dim hover:text-nova-lavender transition-colors">How It Works</a>
        <a
          href="https://github.com/scottventures/nova"
          class="text-nova-text-dim hover:text-nova-lavender transition-colors inline-flex items-center gap-1.5"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-nova-border/20 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-nova-text-dim">
      <span>&copy; {year} Scott Ventures. All rights reserved.</span>
      <span class="flex items-center gap-1">
        Built with
        <svg class="w-3 h-3 text-nova-violet" fill="currentColor" viewBox="0 0 24 24"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/></svg>
        by Scott Ventures
      </span>
    </div>
  </div>
</footer>
