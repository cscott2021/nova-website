<section class="relative min-h-screen flex flex-col items-center justify-center px-6 text-center overflow-hidden pt-20">
  <!-- Layered background -->
  <div class="absolute inset-0 bg-nova-deep"></div>

  <!-- Gradient orbs -->
  <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] rounded-full animate-pulse-glow" style="background: radial-gradient(circle, rgba(124,58,237,0.3) 0%, transparent 70%);"></div>
  <div class="absolute bottom-1/3 right-1/4 w-[400px] h-[400px] rounded-full animate-pulse-glow delay-200" style="background: radial-gradient(circle, rgba(167,139,250,0.2) 0%, transparent 70%);"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full opacity-20" style="background: radial-gradient(circle, rgba(124,58,237,0.4) 0%, transparent 60%);"></div>

  <!-- Star field -->
  <div class="star-field">
    <div class="star" style="top: 10%; left: 15%; animation-delay: 0s;"></div>
    <div class="star" style="top: 20%; left: 80%; animation-delay: 1s;"></div>
    <div class="star" style="top: 40%; left: 5%; animation-delay: 0.5s;"></div>
    <div class="star" style="top: 15%; left: 45%; animation-delay: 2s;"></div>
    <div class="star" style="top: 60%; left: 90%; animation-delay: 1.5s;"></div>
    <div class="star" style="top: 75%; left: 25%; animation-delay: 0.3s;"></div>
    <div class="star" style="top: 30%; left: 65%; animation-delay: 2.5s;"></div>
    <div class="star" style="top: 85%; left: 70%; animation-delay: 0.8s;"></div>
    <div class="star" style="top: 50%; left: 35%; animation-delay: 1.8s;"></div>
    <div class="star" style="top: 5%; left: 55%; animation-delay: 1.2s;"></div>
    <div class="star" style="top: 45%; left: 75%; animation-delay: 0.7s;"></div>
    <div class="star" style="top: 70%; left: 50%; animation-delay: 2.2s;"></div>
    <div class="star" style="top: 92%; left: 12%; animation-delay: 0.4s;"></div>
    <div class="star" style="top: 35%; left: 92%; animation-delay: 1.7s;"></div>
    <div class="star" style="top: 55%; left: 18%; animation-delay: 2.8s;"></div>
    <div class="star" style="top: 8%; left: 72%; animation-delay: 3.1s;"></div>
  </div>

  <!-- Orbiting ring -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] sm:w-[500px] sm:h-[500px] rounded-full border border-nova-violet/10 opacity-50"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[450px] sm:w-[700px] sm:h-[700px] rounded-full border border-nova-violet/5 opacity-30"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto">
    <!-- Badge -->
    <div class="animate-fade-in-up inline-flex items-center gap-2 bg-nova-violet/10 border border-nova-violet/20 rounded-full px-4 py-1.5 mb-8">
      <span class="w-2 h-2 rounded-full bg-nova-success animate-pulse"></span>
      <span class="text-sm text-nova-text-muted font-medium">Now available for macOS</span>
    </div>

    <!-- Nova logo mark -->
    <div class="animate-fade-in-up delay-100 flex justify-center mb-8">
      <div class="relative">
        <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-3xl bg-gradient-to-br from-nova-violet via-nova-violet-light to-nova-lavender flex items-center justify-center shadow-2xl shadow-nova-violet/30 animate-float">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" class="sm:w-14 sm:h-14">
            <g transform="translate(24, 24)">
              <rect x="-1.5" y="-18" width="3" height="36" rx="1.5" fill="white" opacity="0.9"/>
              <rect x="-18" y="-1.5" width="36" height="3" rx="1.5" fill="white" opacity="0.9"/>
              <rect x="-1" y="-13" width="2" height="26" rx="1" fill="white" opacity="0.5" transform="rotate(45)"/>
              <rect x="-1" y="-13" width="2" height="26" rx="1" fill="white" opacity="0.5" transform="rotate(-45)"/>
              <circle r="4" fill="white"/>
            </g>
          </svg>
        </div>
        <!-- Glow ring around logo -->
        <div class="absolute inset-[-8px] rounded-[28px] border border-nova-lavender/20 animate-pulse-glow"></div>
      </div>
    </div>

    <!-- Headline -->
    <h1 class="animate-fade-in-up delay-200 font-heading text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold mb-6 tracking-tight leading-[1.05]">
      <span class="bg-gradient-to-r from-nova-text via-nova-lavender to-nova-text bg-clip-text text-transparent animate-gradient">One cockpit for</span>
      <br/>
      <span class="bg-gradient-to-r from-nova-violet-light via-nova-lavender to-nova-violet bg-clip-text text-transparent animate-gradient">everything you do</span>
    </h1>

    <!-- Subheadline -->
    <p class="animate-fade-in-up delay-300 text-lg sm:text-xl text-nova-text-muted max-w-2xl mx-auto mb-12 leading-relaxed">
      Nova unifies chat, voice, code, and computer control on your Mac — then lets you monitor and command your AI agents from anywhere with the mobile app.
    </p>

    <!-- Beta signup -->
    <div class="animate-fade-in-up delay-400 max-w-md mx-auto mb-6">
      <form id="hero-signup" class="flex flex-col sm:flex-row gap-3">
        <input
          type="text"
          name="name"
          placeholder="Your name"
          required
          class="flex-1 bg-nova-surface/50 border border-nova-border/60 rounded-xl px-4 py-3.5 text-sm text-nova-text placeholder-nova-text-dim outline-none focus:border-nova-violet/60 transition-colors"
        />
        <input
          type="email"
          name="email"
          placeholder="you@email.com"
          required
          class="flex-1 bg-nova-surface/50 border border-nova-border/60 rounded-xl px-4 py-3.5 text-sm text-nova-text placeholder-nova-text-dim outline-none focus:border-nova-violet/60 transition-colors"
        />
        <button
          type="submit"
          class="btn-glow bg-gradient-to-r from-nova-violet to-nova-violet-light hover:from-nova-violet-hover hover:to-nova-violet text-white font-semibold px-6 py-3.5 rounded-xl text-sm transition-all duration-300 whitespace-nowrap"
        >
          Request Access
        </button>
      </form>
      <div id="hero-signup-success" class="hidden mt-4 text-sm text-nova-success font-medium">
        You're on the list! We'll be in touch soon.
      </div>
    </div>

    <div class="animate-fade-in-up delay-500 flex flex-col sm:flex-row items-center justify-center gap-4">
      <p class="text-sm text-nova-text-dim">
        macOS & iOS &middot; Free during beta
      </p>
      <a href="#features" class="text-sm text-nova-lavender hover:text-nova-violet-light transition-colors inline-flex items-center gap-1">
        See what it does
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
      </a>
    </div>
  </div>

  <!-- Scroll fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-nova-deep to-transparent"></div>
</section>
