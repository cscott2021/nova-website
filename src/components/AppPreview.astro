<section class="relative py-16 px-6 overflow-hidden">
  <!-- Glow behind preview -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] rounded-full opacity-15" style="background: radial-gradient(ellipse, #7c3aed 0%, transparent 60%);"></div>

  <div class="relative max-w-5xl mx-auto">
    <!-- Window frame -->
    <div class="rounded-2xl border border-nova-border/60 bg-nova-base/90 overflow-hidden shadow-2xl shadow-nova-violet/10 backdrop-blur-sm">
      <!-- Title bar -->
      <div class="flex items-center gap-2 px-4 py-3 bg-gradient-to-r from-nova-surface/80 to-nova-surface/60 border-b border-nova-border/60">
        <div class="flex gap-2">
          <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
          <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
          <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
        </div>
        <div class="flex-1 flex justify-center">
          <div class="flex items-center gap-2 bg-nova-base/50 rounded-lg px-4 py-1">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" class="opacity-50">
              <g transform="translate(10, 10)">
                <rect x="-0.8" y="-7" width="1.6" height="14" rx="0.8" fill="#a78bfa"/>
                <rect x="-7" y="-0.8" width="14" height="1.6" rx="0.8" fill="#a78bfa"/>
                <circle r="1.5" fill="#a78bfa"/>
              </g>
            </svg>
            <span class="text-xs text-nova-text-dim font-mono">Nova</span>
          </div>
        </div>
        <div class="w-14"></div>
      </div>

      <!-- App content -->
      <div class="flex min-h-[450px] sm:min-h-[500px]">
        <!-- Sidebar -->
        <div class="w-52 border-r border-nova-border/40 bg-nova-deep/80 p-3 hidden md:flex flex-col">
          <!-- User avatar area -->
          <div class="flex items-center gap-2.5 px-3 py-2 mb-4">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-nova-violet to-nova-lavender flex items-center justify-center text-white text-xs font-bold">CS</div>
            <div>
              <div class="text-sm font-medium text-nova-text">Caleb</div>
              <div class="text-xs text-nova-text-dim">Pro Plan</div>
            </div>
          </div>

          <!-- Nav items -->
          <div class="space-y-0.5 mb-6">
            <div class="flex items-center gap-2.5 px-3 py-2 rounded-lg bg-nova-violet/15 border border-nova-violet/20 text-nova-lavender">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
              <span class="text-sm font-medium">Chat</span>
            </div>
            <div class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-nova-text-dim hover:text-nova-text-muted hover:bg-nova-surface/30 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>
              <span class="text-sm">Code</span>
            </div>
            <div class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-nova-text-dim hover:text-nova-text-muted hover:bg-nova-surface/30 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
              <span class="text-sm">Agents</span>
            </div>
            <div class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-nova-text-dim hover:text-nova-text-muted hover:bg-nova-surface/30 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z"/></svg>
              <span class="text-sm">Computer</span>
            </div>
          </div>

          <!-- Project section -->
          <div class="mt-auto">
            <div class="text-xs text-nova-text-dim uppercase tracking-wider px-3 mb-2">Projects</div>
            <div class="space-y-0.5">
              <div class="flex items-center gap-2 px-3 py-1.5 rounded-md text-sm text-nova-text-muted hover:bg-nova-surface/30 transition-colors">
                <div class="w-2 h-2 rounded-full bg-nova-violet"></div>
                Nova App
              </div>
              <div class="flex items-center gap-2 px-3 py-1.5 rounded-md text-sm text-nova-text-dim hover:bg-nova-surface/30 transition-colors">
                <div class="w-2 h-2 rounded-full bg-nova-cyan"></div>
                API Docs
              </div>
              <div class="flex items-center gap-2 px-3 py-1.5 rounded-md text-sm text-nova-text-dim hover:bg-nova-surface/30 transition-colors">
                <div class="w-2 h-2 rounded-full bg-nova-success"></div>
                Marketing Site
              </div>
            </div>
          </div>
        </div>

        <!-- Main chat area -->
        <div class="flex-1 flex flex-col bg-nova-deep/40">
          <!-- Chat header -->
          <div class="flex items-center justify-between px-6 py-3 border-b border-nova-border/30">
            <div class="flex items-center gap-2">
              <h3 class="text-sm font-heading font-semibold text-nova-text">Nova App</h3>
              <span class="text-xs text-nova-text-dim bg-nova-surface/50 px-2 py-0.5 rounded-full">Claude Sonnet</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-nova-surface/50 flex items-center justify-center text-nova-text-dim hover:text-nova-lavender transition-colors cursor-pointer">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/></svg>
              </div>
            </div>
          </div>

          <!-- Messages -->
          <div class="flex-1 px-6 py-6 space-y-6 overflow-hidden">
            <!-- AI greeting -->
            <div class="flex gap-3">
              <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-nova-violet to-nova-lavender flex-shrink-0 flex items-center justify-center">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none">
                  <g transform="translate(10, 10)">
                    <rect x="-0.8" y="-7" width="1.6" height="14" rx="0.8" fill="white"/>
                    <rect x="-7" y="-0.8" width="14" height="1.6" rx="0.8" fill="white"/>
                    <circle r="1.5" fill="white"/>
                  </g>
                </svg>
              </div>
              <div class="flex-1 max-w-lg">
                <div class="text-xs text-nova-text-dim mb-1.5 font-medium">Nova</div>
                <div class="bg-nova-surface/50 rounded-2xl rounded-tl-md px-4 py-3 text-sm text-nova-text leading-relaxed">
                  Welcome back, Caleb. I've reviewed the latest changes to the Nova repository. The desktop build pipeline is green and the API tests are passing. What would you like to work on?
                </div>
              </div>
            </div>

            <!-- User message -->
            <div class="flex justify-end">
              <div class="max-w-sm">
                <div class="text-xs text-nova-text-dim mb-1.5 font-medium text-right">You</div>
                <div class="bg-nova-violet/20 border border-nova-violet/25 rounded-2xl rounded-tr-md px-4 py-3 text-sm text-nova-text leading-relaxed">
                  Help me refactor the auth module. Switch to JWT tokens and add refresh token rotation.
                </div>
              </div>
            </div>

            <!-- AI response with code -->
            <div class="flex gap-3">
              <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-nova-violet to-nova-lavender flex-shrink-0 flex items-center justify-center">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none">
                  <g transform="translate(10, 10)">
                    <rect x="-0.8" y="-7" width="1.6" height="14" rx="0.8" fill="white"/>
                    <rect x="-7" y="-0.8" width="14" height="1.6" rx="0.8" fill="white"/>
                    <circle r="1.5" fill="white"/>
                  </g>
                </svg>
              </div>
              <div class="flex-1 max-w-lg">
                <div class="text-xs text-nova-text-dim mb-1.5 font-medium">Nova</div>
                <div class="bg-nova-surface/50 rounded-2xl rounded-tl-md px-4 py-3 text-sm text-nova-text leading-relaxed">
                  <p class="mb-3">I'll refactor the auth module with JWT tokens and refresh rotation. Here's the approach:</p>

                  <!-- Code block -->
                  <div class="bg-nova-deep rounded-xl border border-nova-border/40 overflow-hidden mb-3">
                    <div class="flex items-center justify-between px-3 py-1.5 border-b border-nova-border/30">
                      <span class="text-xs text-nova-text-dim font-mono">auth.service.ts</span>
                      <span class="text-xs text-nova-success">modified</span>
                    </div>
                    <div class="p-3 font-mono text-xs leading-relaxed" set:html={`<span class="text-purple-400">export class</span> <span class="text-sky-300">AuthService</span> {
  <span class="text-purple-400">async</span> <span class="text-blue-300">generateTokenPair</span>(<span class="text-orange-300">userId</span>: <span class="text-sky-300">string</span>) {
    <span class="text-purple-400">const</span> accessToken = <span class="text-purple-400">await</span> <span class="text-blue-300">signJwt</span>(
      { sub: userId, type: <span class="text-green-400">'access'</span> },
      { expiresIn: <span class="text-green-400">'15m'</span> }
    );
    <span class="text-purple-400">return</span> { accessToken, refreshToken };
  }
}`}>
                    </div>
                  </div>

                  <p class="text-nova-text-muted">I've spawned an agent to implement the full changes across 4 files. <span class="text-nova-success">Agent running...</span></p>
                </div>
              </div>
            </div>
          </div>

          <!-- Input area -->
          <div class="px-6 py-4 border-t border-nova-border/30">
            <div class="flex items-center gap-3">
              <div class="flex-1 flex items-center bg-nova-surface/40 border border-nova-border/40 rounded-2xl px-4 py-3 focus-within:border-nova-violet/40 transition-colors">
                <input type="text" placeholder="Message Nova..." class="flex-1 bg-transparent text-sm text-nova-text placeholder-nova-text-dim outline-none" disabled />
                <div class="flex items-center gap-2 ml-2">
                  <div class="w-7 h-7 rounded-lg flex items-center justify-center text-nova-text-dim hover:text-nova-lavender transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18.375 12.739l-7.693 7.693a4.5 4.5 0 01-6.364-6.364l10.94-10.94A3 3 0 1119.5 7.372L8.552 18.32m.009-.01l-.01.01m5.699-9.941l-7.81 7.81a1.5 1.5 0 002.112 2.13"/></svg>
                  </div>
                </div>
              </div>
              <button class="w-10 h-10 rounded-xl bg-nova-violet flex items-center justify-center text-white hover:bg-nova-violet-hover transition-colors flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Reflection/shadow -->
    <div class="h-20 bg-gradient-to-b from-nova-violet/5 to-transparent rounded-b-3xl -mt-1 mx-4"></div>
  </div>
</section>
